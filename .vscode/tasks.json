{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build physics",
            "type": "shell",
            "command": "make",
            "args": [
                "build_physics",
                "PHYSICS=${input:selectedPhysics}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "make",
            "args": [
                "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        }
    ],
    "inputs": [
        {
            "id": "selectedPhysics",
            "type": "pickString",
            "description": "Select the simulation physics module to build/debug",
            "options": [
                "heat/1d_implicit",
                "heat/1d_explicit",
                "heat/2d_implicit",
                "heat/3d_implicit",
                "reservoir/1d",
                "reservoir/2d",
                "reservoir/3d",
                "reservoir/black_oil_2d",
                "reservoir/dual_2d",
                "reservoir/oil_gas_2d",
                "reservoir/mba",
                "pressure/1d",
                "wave/1d"
            ],
            "default": "reservoir/2d"
        }
    ]
}