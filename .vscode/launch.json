{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Simulation Physics",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/dist/${input:selectedPhysics}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/src",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build physics",
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "Launch Streamlit UI",
            "type": "python",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "${workspaceFolder}/web/app.py"
            ],
            "cwd": "${workspaceFolder}/ui",
            "python": "${workspaceFolder}/.venv/bin/python",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/bindings/python"
            },
            "console": "integratedTerminal"
        }
    ],
    "inputs": [
        {
            "id": "selectedPhysics",
            "type": "pickString",
            "description": "Select the simulation physics module to build/debug",
            "options": [
                "heat/1d_implicit",
                "heat/1d_explicit",
                "heat/2d_implicit",
                "heat/3d_implicit",
                "reservoir/1d",
                "reservoir/2d",
                "reservoir/3d",
                "reservoir/black_oil_2d",
                "reservoir/dual_2d",
                "reservoir/oil_gas_2d",
                "reservoir/mba",
                "pressure/1d",
                "wave/1d"
            ],
            "default": "reservoir/2d"
        }
    ]
}